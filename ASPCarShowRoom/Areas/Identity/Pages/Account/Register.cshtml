@page
@model RegisterModel
@{
    ViewData["Title"] = "Регистрация";
}

<div class="register-container">

    <div class="register-card shadow-lg">

        <div class="text-center mb-4">
            <h1 class="register-title">Създай профил</h1>
            <p class="register-subtitle">
                Регистрирай се в системата
            </p>
        </div>

        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">

            <div asp-validation-summary="ModelOnly"
                 class="alert alert-danger"
                 role="alert">
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Email"
                       class="form-control custom-input"
                       autocomplete="username"
                       placeholder="name@example.com" />

                <label asp-for="Input.Email">
                    Имейл адрес
                </label>

                <span asp-validation-for="Input.Email"
                      class="text-danger">
                </span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.UserName"
                       class="form-control custom-input"
                       placeholder="Потребителско име" />

                <label asp-for="Input.UserName">
                    Потребителско име
                </label>

                <span asp-validation-for="Input.UserName"
                      class="text-danger">
                </span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.FirstName"
                       class="form-control custom-input"
                       placeholder="Собствено име" />

                <label asp-for="Input.FirstName">
                    Собствено име
                </label>

                <span asp-validation-for="Input.FirstName"
                      class="text-danger">
                </span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.LastName"
                       class="form-control custom-input"
                       placeholder="Фамилно име" />

                <label asp-for="Input.LastName">
                    Фамилно име
                </label>

                <span asp-validation-for="Input.LastName"
                      class="text-danger">
                </span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.PhoneNumber"
                       class="form-control custom-input"
                       placeholder="Телефонен номер" />

                <label asp-for="Input.PhoneNumber">
                    Телефонен номер
                </label>

                <span asp-validation-for="Input.PhoneNumber"
                      class="text-danger">
                </span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Address"
                       class="form-control custom-input"
                       placeholder="Адрес" />

                <label asp-for="Input.Address">
                    Адрес
                </label>

                <span asp-validation-for="Input.Address"
                      class="text-danger">
                </span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Password"
                       class="form-control custom-input"
                       autocomplete="new-password"
                       placeholder="Парола" />

                <label asp-for="Input.Password">
                    Парола
                </label>

                <span asp-validation-for="Input.Password"
                      class="text-danger">
                </span>
            </div>

            <div class="form-floating mb-4">
                <input asp-for="Input.ConfirmPassword"
                       class="form-control custom-input"
                       autocomplete="new-password"
                       placeholder="Потвърди парола" />

                <label asp-for="Input.ConfirmPassword">
                    Потвърди парола
                </label>

                <span asp-validation-for="Input.ConfirmPassword"
                      class="text-danger">
                </span>
            </div>

            <button id="registerSubmit"
                    type="submit"
                    class="btn register-btn w-100">
                Регистрирай се
            </button>

        </form>

        <div class="external-login mt-5">

            <h5 class="text-center mb-3">
                Вход чрез външен профил
            </h5>

            <hr />

            @{
                if ((Model.ExternalLogins?.Count ?? 0) == 0)
                {
                    <div class="alert alert-info text-center">
                        Няма налични външни услуги за вход.
                    </div>
                }
                else
                {
                    <form id="external-account"
                          asp-page="./ExternalLogin"
                          asp-route-returnUrl="@Model.ReturnUrl"
                          method="post">

                        <div class="d-grid gap-2">

                            @foreach (var provider in Model.ExternalLogins!)
                            {
                                <button type="submit"
                                        class="btn btn-outline-primary"
                                        name="provider"
                                        value="@provider.Name">

                                    Вход с @provider.DisplayName

                                </button>
                            }

                        </div>
                    </form>
                }
            }

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}