@page
@model LoginModel

@{
    ViewData["Title"] = "Вход";
}

<div class="login-container">
    <div class="login-card shadow-lg">
        <div class="text-center mb-4">
            <h1 class="login-title">
                Добре дошли
            </h1>

            <p class="login-subtitle">
                Влез в своя профил
            </p>
        </div>
        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly"
                 class="alert alert-danger"
                 role="alert">
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.UserName"
                       class="form-control custom-input"
                       autocomplete="username"
                       placeholder="Потребителско име" />
                <label asp-for="Input.UserName">
                    Потребителско име
                </label>
                <span asp-validation-for="Input.UserName"
                      class="text-danger">
                </span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Password"
                       class="form-control custom-input"
                       autocomplete="current-password"
                       placeholder="Парола" />
                <label asp-for="Input.Password">
                    Парола
                </label>
                <span asp-validation-for="Input.Password"
                      class="text-danger">
                </span>
            </div>

            <div class="form-check mb-4">
                <input class="form-check-input" asp-for="Input.RememberMe" />
                <label class="form-check-label" asp-for="Input.RememberMe">
                    Запомни ме
                </label>
            </div>

            <button id="login-submit"
                    type="submit"
                    class="btn login-btn w-100">
                Вход
            </button>
            <div class="login-links mt-4 text-center">
                <p>
                    <a id="forgot-password"
                       asp-page="./ForgotPassword">
                        Забравена парола?
                    </a>
                </p>

                <p>
                    <a asp-page="./Register"
                       asp-route-returnUrl="@Model.ReturnUrl">
                        Нямаш профил? Регистрирай се
                    </a>
                </p>

                <p>
                    <a id="resend-confirmation"
                       asp-page="./ResendEmailConfirmation">
                        Изпрати повторно потвърждение
                    </a>
                </p>
            </div>
        </form>
        <div class="external-login mt-5">
            <h5 class="text-center mb-3">
                Вход чрез външен профил
            </h5>

            <hr />

            @if ((Model.ExternalLogins?.Count ?? 0) == 0)
            {
                <div class="alert alert-info text-center">
                    Няма налични външни услуги за вход.
                </div>
            }
            else
            {
                <form id="external-account"
                      asp-page="./ExternalLogin"
                      asp-route-returnUrl="@Model.ReturnUrl"
                      method="post">
                    <div class="d-grid gap-2">
                        @foreach (var provider in Model.ExternalLogins!)
                        {
                            <button type="submit"
                                    class="btn btn-outline-primary external-btn"
                                    name="provider"
                                    value="@provider.Name">
                                Вход с @provider.DisplayName
                            </button>
                        }
                    </div>
                </form>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}