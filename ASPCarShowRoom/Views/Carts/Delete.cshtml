@model ASPCarShowRoom.Models.Cart

@{
    ViewData["Title"] = "Изтриване на поръчка";
}

<div class="delete-page">
    <div class="delete-header text-center">
        <h1 class="delete-title">
            Изтриване на поръчка
        </h1>
        <p class="delete-subtitle">
            Сигурен ли си, че искаш да изтриеш тази поръчка?
        </p>
    </div>
    <div class="delete-card">
        <div class="delete-warning">
            ⚠️ Това действие не може да бъде върнато назад.
        </div>
        <div class="delete-info">
            <div class="info-row">
                <span class="info-label">
                    Клиент
                </span>
                <span class="info-value">
                    @Model.Clients.UserName
                </span>
            </div>
            <div class="info-row">
                <span class="info-label">
                    Автомобил
                </span>
                <span class="info-value">
                    @Model.Cars.CarModel
                </span>
            </div>
            <div class="info-row">
                <span class="info-label">
                    Съобщение
                </span>
                <span class="info-value">
                    @Model.Message
                </span>
            </div>
            <div class="info-row">
                <span class="info-label">
                    Дата на добавяне
                </span>
                <span class="info-value">
                    @Model.RegisterOn
                </span>
            </div>
        </div>
        <form asp-action="Delete"
              class="delete-actions">
            <input type="hidden"
                   asp-for="Id" />
            <button type="submit"
                    class="delete-btn">
                Изтрий поръчката
            </button>
            <a asp-action="Index"
               class="cancel-btn">
                Отказ
            </a>
        </form>
    </div>
</div>