@model ASPCarShowRoom.Models.Cart

@{
    ViewData["Title"] = "Детайли за поръчка";
}

<div class="order-details-page">
    <div class="details-header text-center">
        <h1 class="details-title">
            Детайли за поръчка
        </h1>
        <p class="details-subtitle">
            Информация за избраната автомобилна поръчка
        </p>
    </div>
    <div class="details-card">
        <div class="details-item">
            <span class="details-label">
                Клиент
            </span>
            <span class="details-value">
                @Model.Clients.UserName
            </span>
        </div>
        <div class="details-item">
            <span class="details-label">
                Автомобил
            </span>
            <span class="details-value">
                @Model.Cars.CarModel
            </span>
        </div>
        <div class="details-item">
            <span class="details-label">
                Съобщение
            </span>
            <span class="details-value">
                @Model.Message
            </span>
        </div>
        <div class="details-item">
            <span class="details-label">
                Дата на поръчка
            </span>
            <span class="details-value">
                @Model.RegisterOn
            </span>
        </div>
        <div class="details-actions">
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Edit"
                   asp-route-id="@Model?.Id"
                   class="edit-btn">
                    Редактирай
                </a>
            }
            <a asp-action="Index"
               class="back-btn">
                Назад към поръчките
            </a>
        </div>
    </div>
</div>