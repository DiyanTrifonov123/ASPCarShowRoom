@model ASPCarShowRoom.Models.Car

@{
    ViewData["Title"] = "Детайли за автомобил";
}

<div class="car-details-page">
    <div class="car-details-header text-center">
        <h1 class="car-details-title">
            @Model.CarModel
        </h1>
        <p class="car-details-subtitle">
            Подробна информация за автомобила
        </p>
    </div>
    <div class="car-details-card">
        <div class="car-image-section">
            <img src="@Model.Image"
                 alt="@Model.CarModel"
                 class="car-details-image" />
        </div>
        <div class="car-info-section">
            <div class="info-row">
                <span class="info-label">
                    Модел
                </span>
                <span class="info-value">
                    @Model.CarModel
                </span>
            </div>
            <div class="info-row">
                <span class="info-label">
                    Описание
                </span>
                <span class="info-value">
                    @Model.Description
                </span>
            </div>
            <div class="info-row">
                <span class="info-label">
                    Година
                </span>
                <span class="info-value">
                    @Model.Year
                </span>
            </div>
            <div class="info-row">
                <span class="info-label">
                    Оборудване
                </span>
                <span class="info-value">
                    @Model.Equipments.Name
                </span>
            </div>
            <div class="info-row">
                <span class="info-label">
                    Състояние
                </span>
                <span class="info-value">

                    @(Model.IsNew ? "Нов автомобил" : "Употребяван автомобил")

                </span>
            </div>
            <div class="info-row">
                <span class="info-label">
                    Вид гориво
                </span>
                <span class="info-value">
                    @Model.FuelTypes.Name
                </span>
            </div>
            <div class="info-row">
                <span class="info-label">
                    Мощност
                </span>
                <span class="info-value">
                    @Model.Power к.с.
                </span>
            </div>
            <div class="info-row">
                <span class="info-label">
                    Ускорение
                </span>
                <span class="info-value">
                    @Model.Acceleration н.м.
                </span>
            </div>
            <div class="info-row">
                <span class="info-label">
                    Цена
                </span>
                <span class="car-price">
                    @Model.Price лв.
                </span>
            </div>
            <div class="info-row">
                <span class="info-label">
                    Добавен на
                </span>
                <span class="info-value">
                    @Model.RegisterOn
                </span>
            </div>
            <div class="car-details-actions">
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Edit"
                       asp-route-id="@Model?.Id"
                       class="edit-btn">
                        Редактирай
                    </a>
                }
                <a asp-action="Index"
                   class="back-btn">
                    Назад към автомобилите
                </a>
            </div>
        </div>
    </div>
</div>