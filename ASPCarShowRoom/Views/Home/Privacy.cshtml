@{
    ViewData["Title"] = "Контакти и сервиз";
}

<div class="contact-page">
    <div class="contact-header text-center">
        <h1 class="contact-title">
            Контакти и сервиз
        </h1>
        <p class="contact-subtitle">
            Свържете се с екипа на Volkswagen Love
        </p>
    </div>
    <div class="contact-grid">
        <div class="contact-card">
            <h3>
                Информация за контакт
            </h3>
            <div class="contact-info">
                <div class="info-box">
                    <span class="info-label">
                        Адрес
                    </span>
                    <p>
                        гр. Сопот
                    </p>
                </div>
                <div class="info-box">
                    <span class="info-label">
                        Телефон
                    </span>
                    <p>
                        +359 88 123 4567
                    </p>
                </div>
                <div class="info-box">
                    <span class="info-label">
                        Имейл
                    </span>
                    <p>
                        info@vw-love.bg
                    </p>
                </div>
                <div class="info-box">
                    <span class="info-label">
                        Работно време
                    </span>
                    <p>
                        Понеделник – Петък:
                        09:00 – 18:00
                    </p>
                    <p>
                        Събота:
                        10:00 – 14:00
                    </p>
                </div>
            </div>
        </div>
        <div class="contact-card">
            <h3>
                Изпрати съобщение
            </h3>
            <form method="post"
                  class="contact-form">
                <div class="form-group">
                    <label>
                        Име
                    </label>
                    <input type="text"
                           class="form-control"
                           placeholder="Въведете име"
                           required />
                </div>
                <div class="form-group">
                    <label>
                        Имейл
                    </label>
                    <input type="email"
                           class="form-control"
                           placeholder="example@email.com"
                           required />
                </div>
                <div class="form-group">
                    <label>
                        Съобщение
                    </label>
                    <textarea class="form-control"
                              rows="5"
                              placeholder="Вашето съобщение..."
                              required></textarea>
                </div>
                <button type="submit"
                        class="send-btn">
                    Изпрати съобщение
                </button>
            </form>
        </div>
    </div>
    <div class="map-section">
        <h3 class="map-title text-center">
            Нашата локация
        </h3>
        <div class="map-container">
            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d11737.714045664901!2d24.7499009!3d42.65227395!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x40a990c52cb15c7f%3A0xc2dd6f2c7c4bc02d!2zNDMzMCDQodC-0L_QvtGC!5e0!3m2!1sbg!2sbg!4v1774342327184!5m2!1sbg!2sbg"
                    allowfullscreen=""
                    loading="lazy">
            </iframe>
        </div>
    </div>
</div>